{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clinkz.dev/schemas/wot/performance-result-v2.json",
  "title": "clinkz-wot performance result v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workload_id",
    "workload_version",
    "profile",
    "resource_profile",
    "manifest_sha256",
    "fixture_id",
    "fixture_sha256",
    "harness_case",
    "measurement_sha256",
    "feature_set",
    "target",
    "toolchain",
    "allocator",
    "runner_class",
    "runner_fingerprint",
    "runner_fingerprint_sha256",
    "status",
    "sample_count",
    "failed_samples",
    "metrics"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "workload_id": { "type": "string", "minLength": 1 },
    "workload_version": { "type": "integer", "minimum": 1 },
    "profile": { "type": "string", "minLength": 1 },
    "resource_profile": { "type": "string", "minLength": 1 },
    "manifest_sha256": { "pattern": "^[0-9a-f]{64}$" },
    "fixture_id": { "type": "string", "minLength": 1 },
    "fixture_sha256": { "pattern": "^[0-9a-f]{64}$" },
    "harness_case": { "pattern": "^[a-z][a-z0-9_]*$" },
    "measurement_sha256": { "pattern": "^[0-9a-f]{64}$" },
    "feature_set": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "toolchain": { "type": "string", "minLength": 1 },
    "allocator": { "type": "string", "minLength": 1 },
    "runner_class": { "type": "string", "minLength": 1 },
    "runner_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "board",
        "class",
        "clock_source",
        "cpu_model",
        "frequency_policy",
        "kernel_or_runtime",
        "memory",
        "os_or_firmware",
        "physical_cores",
        "threads_per_core"
      ],
      "properties": {
        "board": { "type": "string", "minLength": 1 },
        "class": { "type": "string", "minLength": 1 },
        "clock_source": { "type": "string", "minLength": 1 },
        "cpu_model": { "type": "string", "minLength": 1 },
        "frequency_policy": { "type": "string", "minLength": 1 },
        "kernel_or_runtime": { "type": "string", "minLength": 1 },
        "memory": { "type": "string", "minLength": 1 },
        "os_or_firmware": { "type": "string", "minLength": 1 },
        "physical_cores": { "type": "string", "minLength": 1 },
        "threads_per_core": { "type": "string", "minLength": 1 }
      }
    },
    "runner_fingerprint_sha256": { "pattern": "^sha256:[0-9a-f]{64}$" },
    "status": { "enum": ["passed", "failed", "characterization", "unavailable"] },
    "sample_count": { "type": "integer", "minimum": 0 },
    "failed_samples": { "type": "integer", "minimum": 0 },
    "coverage_sha256": { "pattern": "^sha256:[0-9a-f]{64}$" },
    "coverage_cell_count": { "type": "integer", "minimum": 1 },
    "samples_per_cell": { "type": "integer", "minimum": 1 },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "enum": ["passed", "characterization"] }
        }
      },
      "then": {
        "properties": {
          "sample_count": { "minimum": 1 },
          "failed_samples": { "const": 0 },
          "metrics": { "minProperties": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "unavailable" }
        }
      },
      "then": {
        "properties": {
          "sample_count": { "const": 0 },
          "failed_samples": { "const": 0 },
          "metrics": { "maxProperties": 0 }
        }
      }
    },
    {
      "if": {
        "anyOf": [
          { "required": ["coverage_sha256"] },
          { "required": ["coverage_cell_count"] },
          { "required": ["samples_per_cell"] }
        ]
      },
      "then": {
        "required": [
          "coverage_sha256",
          "coverage_cell_count",
          "samples_per_cell"
        ]
      }
    }
  ]
}
